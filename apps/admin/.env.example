# URL base del backend. Puede incluir o no `/api/v1`.
VITE_API_URL=http://localhost:8000/api/v1

# true: usa datos locales navegables. false: consume VITE_API_URL.
# Si se omite, la aplicación arranca de forma segura en modo demo.
VITE_DEMO_MODE=true

# Token opcional para desarrollo contra la API. No lo confirmes en el repositorio.
VITE_API_TOKEN=
